---
import { site } from '../data/site';

const {
  current = '',
  whatsappHref = site.whatsappUrl('Hola Bruno, quiero consultar por una estadia en Experiencias Mendoza')
} = Astro.props;
---

<header class="topbar">
  <div class="container topbar-inner">
    <a href="/" class="brand">
      <strong>{site.brand}</strong>
      <span>Casas para vivir Mendoza con otro ritmo</span>
    </a>

    <div class="nav-wrap">
      <nav class="main-nav">
        <a href="/" aria-current={current === 'home' ? 'page' : undefined}>Home</a>
        <a href="/la-casa-frente-al-parque" aria-current={current === 'parque' ? 'page' : undefined}>Parque</a>
        <a href="/casa-avellaneda" aria-current={current === 'avellaneda' ? 'page' : undefined}>Avellaneda</a>
        <a href="/servicios" aria-current={current === 'servicios' ? 'page' : undefined}>Servicios</a>
      </nav>

      <a class="btn btn-primary whatsapp-top" href={whatsappHref} target="_blank" rel="noreferrer">
        WhatsApp
      </a>
    </div>
  </div>
</header>

<style>
  .nav-wrap {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .whatsapp-top {
    min-height: 42px;
    padding: 0 16px;
    white-space: nowrap;
  }

  .main-nav a[aria-current='page'] {
    color: var(--text);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .nav-wrap {
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
    }

    .whatsapp-top {
      width: 100%;
      justify-content: center;
    }
  }
</style>
