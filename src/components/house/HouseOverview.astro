---
const { house } = Astro.props;

const capacity = house.capacity ?? house.capacidad ?? '14';
const bedrooms = house.bedrooms ?? house.habitaciones ?? 'varios';
const bathrooms = house.bathrooms ?? house.banos ?? house.baños ?? 'varios';
const title = house.experienceTitle ?? 'Una casa pensada para vivir Mendoza con comodidad.';
const summary = house.experienceSummary ?? house.summary;
---

<section class="section overview" id="experiencia">
  <div class="shell overview-card">
    <div>
      <span class="section-label">La experiencia</span>
      <h2>{title}</h2>
      <p>
        {summary}
      </p>
    </div>

    <div class="overview-grid">
      <article>
        <strong>{capacity}</strong>
        <span>hu&eacute;spedes</span>
      </article>

      <article>
        <strong>{bedrooms}</strong>
        <span>dormitorios</span>
      </article>

      <article>
        <strong>{bathrooms}</strong>
        <span>ba&ntilde;os</span>
      </article>

      <article>
        <strong>{house.location ?? 'Mendoza'}</strong>
        <span>ubicaci&oacute;n</span>
      </article>
    </div>
  </div>
</section>

<style>
.overview {
  padding: 56px 0;
}

.overview-card {
  background: rgba(255,255,255,.74);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 34px;
  box-shadow: var(--shadow);
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 32px;
}

.section-label {
  display: block;
  margin-bottom: 12px;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: .12em;
  color: var(--olive);
  font-weight: 700;
}

.overview-card h2 {
  font-size: clamp(32px, 4vw, 52px);
  line-height: .95;
  margin: 0 0 16px;
}

.overview-card p {
  color: var(--muted);
  line-height: 1.6;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}

.overview-grid article {
  background: #f6f0ea;
  border: 1px solid var(--line);
  border-radius: 16px;
  padding: 22px;
}

.overview-grid strong {
  display: block;
  font-size: 26px;
}

.overview-grid span {
  color: var(--muted);
  font-size: 14px;
}

@media (max-width: 850px) {
  .overview-card {
    grid-template-columns: 1fr;
    padding: 28px;
  }
}
</style>
