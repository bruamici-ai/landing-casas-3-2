---
const { house, wa } = Astro.props;

const img = (i) => house.images?.[i] || house.images?.[0];

const title = house.heroTitle ?? 'Mendoza empieza en los portones del parque.';
const summary = house.summary;
---

<section class="hero">
  <div class="shell hero-layout">
    <div class="hero-copy">
      <p class="eyebrow">CASA COMPLETA · FRENTE AL PARQUE GENERAL SAN MARTÍN</p>

      <h1>{title}</h1>

      <p class="lead">{summary}</p>

      <div class="hero-actions">
        <a class="button primary" href={wa}>Consultar disponibilidad</a>
        <a class="button quiet" href="#experiencia">Ver la casa</a>
      </div>

      <div class="mini-proof">
        <span>⭐ 4.8/5</span>
        <span>{house.capacity} huéspedes</span>
        <span>Frente al Parque</span>
      </div>
    </div>

    <div class="hero-gallery">
      <div class="main-image">
        <img src={img(0)} alt={`Living principal de ${house.name}`} />
      </div>

      <div class="side-images">
        <img src={img(1)} alt={`Dormitorio de ${house.name}`} />
        <img src={img(2)} alt={`Exterior de ${house.name}`} />
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  padding: 56px 0 72px;
}

.hero-layout {
  display: grid;
  grid-template-columns: minmax(320px, .8fr) minmax(0, 1.2fr);
  gap: 28px;
  align-items: center;
}

.hero-copy {
  padding: 24px 0;
}

.eyebrow {
  margin: 0 0 14px;
  font-size: 12px;
  line-height: 1.2;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: #9a4650;
  font-weight: 800;
}

h1 {
  max-width: 660px;
  margin: 0;
  font-size: clamp(44px, 6vw, 82px);
  line-height: .9;
  letter-spacing: -.055em;
}

.lead {
  max-width: 560px;
  margin: 22px 0 0;
  color: #5f5651;
  font-size: clamp(17px, 1.45vw, 21px);
  line-height: 1.55;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 46px;
  padding: 0 18px;
  border-radius: 999px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 800;
  transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
}

.button:hover {
  transform: translateY(-1px);
}

.button.primary {
  background: #1f3d2b;
  color: white;
  box-shadow: 0 14px 34px rgba(31, 61, 43, .22);
}

.button.quiet {
  background: #fff;
  color: #201916;
  border: 1px solid rgba(0,0,0,.08);
}

.mini-proof {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 22px;
}

.mini-proof span {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  background: #fff;
  border: 1px solid rgba(0,0,0,.07);
  color: #4f4641;
  font-size: 13px;
  font-weight: 700;
}

.hero-gallery {
  display: grid;
  grid-template-columns: 1.35fr .7fr;
  gap: 12px;
  min-height: 620px;
}

.main-image,
.side-images img {
  overflow: hidden;
  border-radius: 28px;
  background: #ddd;
  box-shadow: 0 24px 70px rgba(0,0,0,.10);
}

.main-image img,
.side-images img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Ajuste fino: evita que el living quede raro arriba */
.main-image img {
  object-position: center center;
}

.side-images {
  display: grid;
  gap: 12px;
}

.side-images img:first-child {
  object-position: center center;
}

.side-images img:last-child {
  object-position: center center;
}

@media (max-width: 950px) {
  .hero {
    padding: 34px 0 48px;
  }

  .hero-layout {
    grid-template-columns: 1fr;
  }

  .hero-copy {
    padding: 0;
  }

  h1 {
    font-size: clamp(42px, 11vw, 66px);
  }

  .hero-gallery {
    min-height: auto;
    grid-template-columns: 1fr;
  }

  .main-image {
    height: 58vh;
    min-height: 420px;
  }

  .side-images {
    grid-template-columns: 1fr 1fr;
  }

  .side-images img {
    height: 220px;
  }
}

@media (max-width: 560px) {
  .hero {
    padding-top: 24px;
  }

  .hero-actions {
    flex-direction: column;
  }

  .button {
    width: 100%;
  }

  .main-image {
    min-height: 360px;
    height: 52vh;
    border-radius: 22px;
  }

  .side-images {
    grid-template-columns: 1fr;
  }

  .side-images img {
    height: 240px;
    border-radius: 22px;
  }
}
</style>