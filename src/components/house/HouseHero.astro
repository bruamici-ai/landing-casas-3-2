---
import { cloudinaryImage } from '../../utils/cloudinary';

const { house, reviewRatings } = Astro.props;

const img = (i) => house.images?.[i] || house.images?.[0];

const title = house.heroTitle ?? 'Mendoza empieza en los portones del parque.';
const summary = house.heroSummary ?? house.summary;
const eyebrow = house.eyebrow ?? 'CASA COMPLETA · FRENTE AL PARQUE GENERAL SAN MARTIN';
const airbnbRating = reviewRatings?.airbnb?.toFixed(1);
const bookingRating = reviewRatings?.booking?.toFixed(1);
---

<section class="hero">
  <div class="shell hero-layout">
    <div class="hero-copy">
      <p class="eyebrow">{eyebrow}</p>

      <h1>{title}</h1>

      <p class="lead">{summary}</p>

      <div class="mini-proof">
        {airbnbRating && <span>Airbnb ⭐ {airbnbRating}/5</span>}
        {bookingRating && <span>Booking ⭐ {bookingRating}/10</span>}
      </div>
    </div>

    <div class="hero-gallery">
      <div class="main-image">
        <img src={cloudinaryImage(img(0), 'q_auto,f_auto,c_limit,w_1600')} alt={`Living principal de ${house.name}`} fetchpriority="high" />
      </div>

      <div class="side-images">
        <img src={cloudinaryImage(img(1), 'q_auto,f_auto,c_limit,w_900')} alt={`Dormitorio de ${house.name}`} loading="lazy" />
        <img src={cloudinaryImage(img(2), 'q_auto,f_auto,c_limit,w_900')} alt={`Exterior de ${house.name}`} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  padding: 72px 0 34px;
}

.hero-layout {
  display: grid;
  grid-template-columns: minmax(320px, .8fr) minmax(0, 1.2fr);
  gap: 28px;
  align-items: center;
}

.hero-copy {
  padding: 24px 0;
}

.eyebrow {
  margin: 0 0 14px;
  font-size: 12px;
  line-height: 1.2;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--olive);
  font-weight: 700;
}

h1 {
  max-width: 660px;
  margin: 0;
  font-size: clamp(44px, 6vw, 82px);
  line-height: .9;
  letter-spacing: -.055em;
}

.lead {
  max-width: 560px;
  margin: 22px 0 0;
  color: var(--muted);
  font-size: clamp(17px, 1.45vw, 21px);
  line-height: 1.55;
}

.mini-proof {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 22px;
}

.mini-proof span {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.78);
  border: 1px solid var(--line);
  color: var(--text);
  font-size: 13px;
  font-weight: 700;
}

.hero-gallery {
  display: grid;
  grid-template-columns: 1.35fr .7fr;
  gap: 12px;
  min-height: 620px;
}

.main-image,
.side-images img {
  overflow: hidden;
  border-radius: 28px;
  background: #ddd;
  box-shadow: var(--shadow);
}

.main-image img,
.side-images img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.main-image img {
  object-position: center center;
}

.side-images {
  display: grid;
  gap: 12px;
}

.side-images img:first-child {
  object-position: center center;
}

.side-images img:last-child {
  object-position: center center;
}

@media (max-width: 950px) {
  .hero {
    padding: 34px 0 48px;
  }

  .hero-layout {
    grid-template-columns: 1fr;
  }

  .hero-copy {
    padding: 0;
  }

  h1 {
    font-size: clamp(42px, 11vw, 66px);
  }

  .hero-gallery {
    min-height: auto;
    grid-template-columns: 1fr;
  }

  .main-image {
    height: 58vh;
    min-height: 420px;
  }

  .side-images {
    grid-template-columns: 1fr 1fr;
  }

  .side-images img {
    height: 220px;
  }
}

@media (max-width: 560px) {
  .hero {
    padding-top: 24px;
  }

  .main-image {
    min-height: 360px;
    height: 52vh;
    border-radius: 22px;
  }

  .side-images {
    grid-template-columns: 1fr;
  }

  .side-images img {
    height: 240px;
    border-radius: 22px;
  }
}
</style>
