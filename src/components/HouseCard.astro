---
const { house } = Astro.props;
---

<a class="house-card" href={`/${house.slug}`}>
  <div class="card-image">
    <img src={house.heroImage} alt={house.name} loading="lazy" />
    <span class="card-badge">{house.badge}</span>
  </div>
  <div class="card-body">
    <div class="card-location">{house.location}</div>
    <h3 class="card-name">{house.name}</h3>
    <p class="card-summary">{house.summary}</p>
    <ul class="card-features">
      {house.features.slice(0, 7).map((f: string) => <li>{f}</li>)}
    </ul>
    <span class="card-arrow">Ver casa →</span>
  </div>
</a>

<style>
.house-card {
  display: flex;
  flex-direction: column;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid var(--line, rgba(36,28,22,.11));
  background: #fff;
  text-decoration: none;
  color: inherit;
  box-shadow: 0 14px 42px rgba(48,35,28,.08);
  transition: transform .25s ease, box-shadow .25s ease;
}

.house-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 24px 60px rgba(48,35,28,.14);
}

.card-image {
  position: relative;
  height: 260px;
  overflow: hidden;
}

.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .4s ease;
}

.house-card:hover .card-image img {
  transform: scale(1.04);
}

.card-badge {
  position: absolute;
  bottom: 14px;
  left: 14px;
  padding: 6px 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.92);
  font-size: .76rem;
  font-weight: 800;
  color: #211915;
  box-shadow: 0 4px 14px rgba(0,0,0,.12);
}

.card-body {
  padding: 22px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.card-location {
  font-size: .75rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--wine, #7a2e49);
}

.card-name {
  margin: 0;
  font-size: clamp(1.3rem, 2.5vw, 1.7rem);
  line-height: 1.1;
  letter-spacing: -.04em;
  color: #211915;
}

.card-summary {
  margin: 0;
  font-size: .9rem;
  line-height: 1.65;
  color: #71665e;
}

.card-features {
  list-style: none;
  margin: 4px 0 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.card-features li {
  padding: 6px 12px;
  background: #f6f0ea;
  border-radius: 999px;
  font-size: .78rem;
  font-weight: 700;
  color: #211915;
}

.card-arrow {
  display: inline-block;
  margin-top: 6px;
  font-size: .84rem;
  font-weight: 800;
  color: var(--wine, #7a2e49);
}
</style>