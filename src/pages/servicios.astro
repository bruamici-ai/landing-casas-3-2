---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { services } from '../data/site';
---

<BaseLayout
  title="Servicios | Experiencias Mendoza"
  description="Servicios complementarios para resolver traslados, compras, experiencias, parrilla y detalles regionales durante la estadia en Mendoza."
>
  <SiteHeader current="servicios" />

  <main>
    <section class="services-hero">
      <div class="container">
        <p class="eyebrow">Servicios</p>
        <h1>Complementos para que la estad&iacute;a fluya mejor.</h1>
        <p>
          Traslados, compras, experiencias, parrilla y detalles regionales coordinados alrededor de la casa,
          el grupo y el ritmo real del viaje.
        </p>
      </div>
    </section>

    <section class="cards">
      <div class="container grid">
        {services.map((service) => (
          <a class="card item" href={`/servicios/${service.slug}`}>
            <img src={`/services/${service.slug}.jpg`} alt={service.title} loading="lazy" />
            <div class="item-copy">
              <span class="kicker">Ver servicio</span>
              <h2>{service.title}</h2>
              <p class="short">{service.short}</p>
              <p>{service.body}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>

<style>
  .services-hero {
    padding: 56px 0 34px;
  }

  .services-hero h1 {
    max-width: 820px;
    margin: 0;
    font-size: clamp(42px, 7vw, 78px);
    line-height: .95;
    letter-spacing: -.05em;
  }

  .services-hero p:not(.eyebrow) {
    max-width: 68ch;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: clamp(17px, 1.45vw, 21px);
    line-height: 1.65;
  }

  .cards { padding: 0 0 56px; }

  .grid {
    display:grid;
    grid-template-columns: repeat(3, minmax(0,1fr));
    gap:22px;
  }

  .item {
    display: grid;
    grid-template-rows: 220px 1fr;
    overflow: hidden;
    text-decoration:none;
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
  }

  .item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .item-copy {
    padding: 20px;
  }

  .item:hover {
    transform: translateY(-3px);
    border-color: rgba(109,117,82,.24);
    box-shadow: 0 22px 48px rgba(30,22,16,.10);
  }

  .kicker {
    display: inline-block;
    margin-bottom: 10px;
    color: var(--olive);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
  }

  .item h2 {
    margin:0 0 6px;
    font-size:26px;
    line-height: 1.05;
  }

  .item .short {
    margin:0 0 10px;
    color:var(--olive);
    font-weight:700;
  }

  .item p {
    margin:0;
    line-height:1.75;
    color:var(--muted);
  }

  @media (max-width: 900px) {
    .services-hero {
      padding-top: 34px;
    }

    .grid {
      grid-template-columns:1fr;
      gap: 14px;
    }
  }

  @media (max-width: 560px) {
    .services-hero {
      padding: 32px 0 22px;
    }

    .services-hero h1 {
      font-size: 40px;
      line-height: .98;
      letter-spacing: -.035em;
    }

    .services-hero p:not(.eyebrow) {
      margin-top: 14px;
      font-size: 16px;
      line-height: 1.55;
    }

    .cards {
      padding-bottom: 40px;
    }

    .item {
      grid-template-columns: 112px minmax(0, 1fr);
      grid-template-rows: none;
      min-height: 138px;
      border-radius: 16px;
    }

    .item img {
      min-height: 138px;
    }

    .item-copy {
      min-width: 0;
      padding: 14px;
    }

    .kicker {
      margin-bottom: 7px;
      font-size: 10.5px;
      letter-spacing: .06em;
    }

    .item h2 {
      margin-bottom: 5px;
      font-size: 20px;
    }

    .item .short {
      margin-bottom: 0;
      font-size: 13px;
      line-height: 1.3;
    }

    .item p:not(.short) {
      display: none;
    }
  }
</style>
