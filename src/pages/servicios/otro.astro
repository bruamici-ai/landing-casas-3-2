---
import ServicePage from '../../components/ServicePage.astro';
---

<ServicePage
  title="Otros proyectos"
  description="Espacio flexible para nuevos servicios, experiencias y proyectos complementarios en Experiencias Mendoza."
  heading="Un espacio abierto para los proximos proyectos."
  intro="Algunos pedidos no entran todavia en una categoria fija. Esta pagina queda preparada para sumar nuevas experiencias y servicios cuando esten listos."
  image="/services/otro.jpg"
  imageAlt="Servicio adicional para la estadia"
  service="otro servicio"
  whatsappMessage="Hola Bruno, quiero consultar por un servicio o pedido especial para mi estadia. La idea es: "
>
  <section class="service-section">
    <div class="container service-grid">
      <article class="service-card">
        <strong>Pedidos especiales</strong>
        <p>Solicitudes puntuales vinculadas a la estadia, el grupo o una ocasion particular.</p>
      </article>

      <article class="service-card">
        <strong>Nuevas experiencias</strong>
        <p>Espacio listo para sumar proyectos gastronomicos, turisticos o regionales.</p>
      </article>

      <article class="service-card">
        <strong>Alianzas futuras</strong>
        <p>Base flexible para integrar nuevos proveedores sin rehacer la estructura del sitio.</p>
      </article>
    </div>
  </section>
</ServicePage>
