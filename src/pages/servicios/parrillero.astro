---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
---
<BaseLayout
  title="Parrillero | Experiencias Mendoza"
  description="Coordinación de parrillero externo para grupos o reuniones tranquilas en casa."
>
  <SiteHeader current="servicios" />
  <main>
    <section class="hero-basic">
      <div class="container">
        <p class="eyebrow">Servicio</p>
        <h1>Parrillero</h1>
        <p>
          Una opción pensada para grupos o familias que quieren disfrutar el asado sin ocuparse de cocinar.
        </p>
      </div>
    </section>

    <section class="service-detail">
      <div class="container card wrap">
        <h2>Base de desarrollo</h2>
        <p>
          Más adelante podemos definir mejor esta página con formato del servicio,
          alcances, tiempos de reserva y enfoque visual.
        </p>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .service-detail { padding: 0 0 56px; }
  .wrap { padding: 28px; }
  .wrap h2 { margin: 0 0 10px; }
  .wrap p { margin: 0; color: var(--muted); line-height: 1.75; }
</style>