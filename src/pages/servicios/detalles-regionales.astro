---
import ServicePage from '../../components/ServicePage.astro';

const products = [
  { name: 'Vinos mendocinos seleccionados', price: 'Segun etiqueta' },
  { name: 'Aceite de oliva regional', price: 'Consultar' },
  { name: 'Dulces y mermeladas', price: 'Consultar' },
  { name: 'Alfajores artesanales', price: 'Consultar' },
  { name: 'Conservas y escabeches', price: 'Consultar' },
  { name: 'Frutos secos', price: 'Consultar' },
  { name: 'Picada regional', price: 'A pedido' },
  { name: 'Chocolates o bombones', price: 'Consultar' },
  { name: 'Detalle para bienvenida', price: 'A pedido' },
  { name: 'Caja regalo regional', price: 'A pedido' },
];
---

<ServicePage
  title="Detalles regionales"
  description="Vidriera de productos regionales que pueden sumarse a la estadia en Mendoza."
  heading="Productos regionales para sumar a la llegada o a la estadia."
  intro="Una vidriera simple de detalles mendocinos que podemos dejar preparados en la casa. Los valores se confirman antes de comprar segun stock, marca y tamano del pedido."
  image="/services/detalles-regionales.jpg"
  imageAlt="Productos regionales de Mendoza"
  service="detalles regionales"
  whatsappMessage="Hola Bruno, quiero consultar por detalles regionales para sumar a la estadia. Me interesa: "
>
  <section class="service-section">
    <div class="container service-panel">
      <h2>Una vidriera chica, clara y facil de pedir</h2>
      <p>
        La idea es resolver detalles chicos sin complicar la llegada: vinos, conservas,
        dulces, aceite de oliva, alfajores, picadas o cajas simples para una ocasion especial.
        Antes de comprar se confirma disponibilidad y valor final por WhatsApp.
      </p>
    </div>
  </section>

  <section class="service-section">
    <div class="container product-grid">
      {products.map((product) => (
        <article class="product-card">
          <span>{product.name}</span>
          <strong>{product.price}</strong>
        </article>
      ))}
    </div>
  </section>
</ServicePage>

<style>
  .product-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 12px;
  }

  .product-card {
    min-height: 112px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255,255,255,.72);
    box-shadow: 0 12px 28px rgba(30,22,16,.06);
  }

  .product-card span {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.35;
  }

  .product-card strong {
    font-size: 18px;
  }

  @media (max-width: 980px) {
    .product-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 520px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
