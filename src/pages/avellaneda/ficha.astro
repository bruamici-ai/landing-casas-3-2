---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import InternalNav from '../../components/InternalNav.astro';
import { avellanedaHouse } from '../../data/avellaneda/house';
---

<BaseLayout title="Ficha interna | Casa Avellaneda" description="Base interna de Casa Avellaneda para consulta operativa." noindex>
  <SiteHeader current="avellaneda" />
  <main>
    <section class="hero-basic">
      <div class="container">
        <p class="eyebrow">Interno · Avellaneda</p>
        <h1>Ficha base de {avellanedaHouse.name}</h1>
        <p>Vista interna para consultar perfil, datos clave y amenities base.</p>
      </div>
    </section>
    <section class="content-wrap">
      <div class="container">
        <InternalNav base="avellaneda" />
        <div class="grid-2">
          <article class="card panel"><h2>Perfil</h2><p>{avellanedaHouse.summary}</p></article>
          <article class="card panel"><h2>Datos clave</h2><ul>{avellanedaHouse.features.map((item) => <li>{item}</li>)}</ul></article>
          <article class="card panel"><h2>Amenities base</h2><ul>{avellanedaHouse.amenities.map((item) => <li>{item}</li>)}</ul></article>
          <article class="card panel"><h2>Estado</h2><p>Ficha interna preparada para seguir cargando datos operativos.</p></article>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .content-wrap { padding: 0 0 56px; }
  .grid-2 { display:grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap:22px; }
  .panel { padding:22px; }
  .panel h2 { margin:0 0 10px; font-size:28px; }
  .panel p, .panel ul { margin:0; color:var(--muted); line-height:1.75; }
  .panel ul { padding-left:18px; }
  @media (max-width: 900px) { .grid-2 { grid-template-columns:1fr; } }
</style>
